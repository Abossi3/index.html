<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Briand's Website</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #111827;
      color: white;
    }

    header {
      background: #0ea5e9;
      padding: 15px;
      text-align: center;
      font-size: 24px;
    }

    .container {
      padding: 20px;
      text-align: center;
    }

    button {
      padding: 10px 20px;
      border: none;
      background: #38bdf8;
      color: black;
      cursor: pointer;
      border-radius: 5px;
    }

    button:hover {
      background: #0ea5e9;
    }

    footer {
      margin-top: 40px;
      padding: 10px;
      background: #1e293b;
    }
    img {
      width: 300px;
      border-radius: 12px;
      margin-top: 20px;
    }
  </style>
</head>

<body>

<header>
  My First Website 🚀
</header>

<div class="container">
  <h1>Hello 👋</h1>
  <p>I love reading, watching anime,football, and building cool stuff📕💻⚽</p>
  <h2>My interest</h2>
  <ul>
    <li>watching anime💻</li>
    <li>Reading books📕</li>
    <li>Gaming🎮</li>
  </ul>
  <h3>One of my favorite anime moment🔥</h3>
  <img scr="images/ichi3.png" alt="Horned anime character in a dark transformation with glowing aura" width="300">
  <button onclick="showMessage()">Tap Me😏</button>
</div>

<footer>
  Built by Abossi😎
</footer>

<script>
  function showMessage() {
    alert("You just clicked a button!");
  }
</script>

</body>
</html>
